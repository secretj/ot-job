# === Database (MariaDB, Docker compose 네트워크 내부) ===
DB_NAME=otjob
DB_USER=otjob
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-root-password
# 앱 컨테이너에서 참조. compose 외부 실행 시에만 수정.
# DB_HOST=mariadb
# DB_PORT=3306
# DB_POOL_SIZE=5

# === Kakao OAuth ===
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# PUBLIC_BASE_URL + /kakao/callback 이 Kakao Developer Console redirect URI 와 일치해야 함
KAKAO_REDIRECT_URI=https://otjob.<tailnet>.ts.net/kakao/callback

# === Public URL (Tailscale Funnel 확정 후) ===
PUBLIC_BASE_URL=https://otjob.<tailnet>.ts.net
TAILSCALE_HOSTNAME=otjob

# === Flask ===
FLASK_SECRET_KEY=change-me-random-64-hex

# === 크롤러 ===
CRAWL_INTERVAL_MINUTES=30
CRAWL_MAX_PAGES=5

# === Grafana (infra 담당이 compose 확장 시 사용) ===
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# === 공통 ===
TZ=Asia/Seoul
LOG_LEVEL=INFO

# === 백업 외장볼륨 (infra: scripts/backup.sh 에서 참조) ===
BACKUP_PATH=/Volumes/Backup/ot-job-tracker
